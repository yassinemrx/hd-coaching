generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Role values: "ADMIN" | "USER"

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          String   @default("USER")
  createdAt     DateTime @default(now())
  lastLoginAt   DateTime?

  weightLogs       WeightLog[]
  measurements     BodyMeasurement[]
  photos           ProgressPhoto[]
  dietPlan         DietPlan?
  trainingProgram  TrainingProgram?
}

model WeightLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  weightKg  Float
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model BodyMeasurement {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  chest     Float?
  waist     Float?
  hips      Float?
  thighs    Float?
  arms      Float?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model ProgressPhoto {
  id        String   @id @default(cuid())
  userId    String
  weekLabel String
  photoUrl  String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ────────── Exercise Library (master list) ──────────
model ExerciseLibrary {
  id          String   @id @default(cuid())
  name        String
  category    String   @default("Other") // Push, Pull, Legs, Core, Cardio, Full Body, Olympic, Other
  muscleGroup String?  // chest, back, shoulders, biceps, triceps, quads, hams, glutes, calves, abs, full
  equipment   String?  // Barbell, Dumbbell, Machine, Cable, Bodyweight, Kettlebell, Band
  notes       String?  @db.Text
  defaultSets Int?     @default(3)
  defaultReps String?  @default("8-10")
  defaultRest String?  @default("90s")
  createdAt   DateTime @default(now())

  programExercises Exercise[]

  @@index([category])
}

// ────────── Food Library (master list) ──────────
model Food {
  id        String   @id @default(cuid())
  name      String
  category  String   @default("Other") // Protein, Carbs, Fats, Vegetables, Fruits, Dairy, Drinks, Other
  unit      String   @default("g")     // g, ml, piece, cup, scoop, slice, tbsp
  perAmount Float    @default(100)     // values below are per X units (e.g. per 100g)
  imageUrl  String?                    // food photo — stored in public/uploads/foods/

  // Core macros (always set)
  calories  Float    @default(0)
  protein   Float    @default(0)
  carbs     Float    @default(0)
  fat       Float    @default(0)
  notes     String?
  createdAt DateTime @default(now())

  // ── Extended core (all optional) ──
  netCarbs    Float?
  fiber       Float?
  sodium      Float? // mg
  cholesterol Float? // mg

  // ── Minerals ──
  calcium    Float? // mg
  iron       Float? // mg
  potassium  Float? // mg
  vitaminD   Float? // μg
  magnesium  Float? // mg
  phosphorus Float? // mg
  zinc       Float? // mg
  selenium   Float? // μg
  copper     Float? // mg
  manganese  Float? // mg

  // ── Vitamins ──
  vitaminA        Float? // μg RAE
  vitaminAIU      Float? // IU
  vitaminB6       Float? // mg
  vitaminB12      Float? // μg
  vitaminC        Float? // mg
  vitaminE        Float? // mg
  vitaminK        Float? // μg
  thiamine        Float? // mg (B1)
  riboflavin      Float? // mg (B2)
  niacin          Float? // mg (B3)
  pantothenicAcid Float? // mg (B5)
  folate          Float? // μg (B9)
  choline         Float? // mg
  retinol         Float? // μg
  alphaCarotene   Float? // μg
  betaCarotene    Float? // μg
  lycopene        Float? // μg
  fluoride        Float? // μg
  vitaminD2       Float? // μg
  vitaminD3       Float? // μg
  vitaminDIU      Float? // IU
  caffeine        Float? // mg
  theobromine     Float? // mg

  // ── Sugars ──
  sugar     Float? // g total
  sucrose   Float?
  glucose   Float?
  fructose  Float?
  lactose   Float?
  maltose   Float?
  galactose Float?
  starch    Float?

  // ── Fat breakdown ──
  saturatedFat       Float?
  monounsaturatedFat Float?
  polyunsaturatedFat Float?
  transFat           Float?

  // ── Fatty acids ──
  omega3 Float? // g total
  omega6 Float? // g total
  ala    Float? // Alpha Linolenic Acid
  dha    Float? // Docosahexaenoic Acid
  epa    Float? // Eicosapentaenoic Acid
  dpa    Float? // Docosapentaenoic Acid

  // ── Amino acids (all in g) ──
  alanine        Float?
  arginine       Float?
  asparticAcid   Float?
  cystine        Float?
  glutamicAcid   Float?
  glycine        Float?
  histidine      Float?
  hydroxyproline Float?
  isoleucine     Float?
  leucine        Float?
  lysine         Float?
  methionine     Float?
  phenylalanine  Float?
  proline        Float?
  serine         Float?
  threonine      Float?
  tryptophan     Float?
  tyrosine       Float?
  valine         Float?

  mealItems MealItem[]

  @@index([category])
}

// ────────── Diet plan (per client) ──────────
model DietPlan {
  id        String   @id @default(cuid())
  userId    String   @unique
  title     String
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  macros    MacroTarget?
  meals     Meal[]
}

model MacroTarget {
  id         String   @id @default(cuid())
  dietPlanId String   @unique
  calories   Int
  protein    Int
  carbs      Int
  fat        Int

  dietPlan   DietPlan @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)
}

model Meal {
  id         String   @id @default(cuid())
  dietPlanId String
  name       String
  time       String
  notes      String?  @db.Text
  imageUrl   String?  // meal photo — stored in public/uploads/meals/
  order      Int      @default(0)

  dietPlan   DietPlan @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)
  items      MealItem[]

  @@index([dietPlanId, order])
}

model MealItem {
  id         String  @id @default(cuid())
  mealId     String
  foodId     String?
  customName String? // when not from library
  quantity   Float   @default(0)
  unit       String  @default("g")
  order      Int     @default(0)

  meal       Meal    @relation(fields: [mealId], references: [id], onDelete: Cascade)
  food       Food?   @relation(fields: [foodId], references: [id], onDelete: SetNull)

  @@index([mealId, order])
}

// ────────── Training program (per client) ──────────
model TrainingProgram {
  id        String   @id @default(cuid())
  userId    String   @unique
  title     String
  notes     String?  @db.Text
  startDate DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  days      TrainingDay[]
}

model TrainingDay {
  id        String   @id @default(cuid())
  programId String
  dayLabel  String
  order     Int      @default(0)

  program   TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  exercises Exercise[]

  @@index([programId, order])
}

model Exercise {
  id        String   @id @default(cuid())
  dayId     String
  libraryId String?  // optional link to ExerciseLibrary entry
  name      String
  sets      Int
  reps      String
  rest      String?
  notes     String?  @db.Text
  order     Int      @default(0)

  day       TrainingDay      @relation(fields: [dayId], references: [id], onDelete: Cascade)
  library   ExerciseLibrary? @relation(fields: [libraryId], references: [id], onDelete: SetNull)

  @@index([dayId, order])
}
