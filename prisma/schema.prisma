generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Role values: "ADMIN" | "USER" (SQLite has no enum support)

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          String   @default("USER")
  createdAt     DateTime @default(now())
  lastLoginAt   DateTime?

  weightLogs       WeightLog[]
  measurements     BodyMeasurement[]
  photos           ProgressPhoto[]
  dietPlan         DietPlan?
  trainingProgram  TrainingProgram?
}

model WeightLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  weightKg  Float
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model BodyMeasurement {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  chest     Float?
  waist     Float?
  hips      Float?
  thighs    Float?
  arms      Float?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model ProgressPhoto {
  id        String   @id @default(cuid())
  userId    String
  weekLabel String
  photoUrl  String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model DietPlan {
  id        String   @id @default(cuid())
  userId    String   @unique
  title     String
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  macros    MacroTarget?
  meals     Meal[]
}

model MacroTarget {
  id         String   @id @default(cuid())
  dietPlanId String   @unique
  calories   Int
  protein    Int
  carbs      Int
  fat        Int

  dietPlan   DietPlan @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)
}

model Meal {
  id         String   @id @default(cuid())
  dietPlanId String
  name       String
  time       String
  foods      String   @db.Text
  order      Int      @default(0)

  dietPlan   DietPlan @relation(fields: [dietPlanId], references: [id], onDelete: Cascade)

  @@index([dietPlanId, order])
}

model TrainingProgram {
  id        String   @id @default(cuid())
  userId    String   @unique
  title     String
  notes     String?  @db.Text
  startDate DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  days      TrainingDay[]
}

model TrainingDay {
  id        String   @id @default(cuid())
  programId String
  dayLabel  String
  order     Int      @default(0)

  program   TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  exercises Exercise[]

  @@index([programId, order])
}

model Exercise {
  id        String   @id @default(cuid())
  dayId     String
  name      String
  sets      Int
  reps      String
  rest      String?
  notes     String?  @db.Text
  order     Int      @default(0)

  day       TrainingDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId, order])
}
